{
  "name": "@a2-ai/spackle",
  "version": "0.5.2",
  "description": "spackle project templating, as a WebAssembly module for JS hosts.",
  "repository": "https://github.com/a2-ai/spackle",
  "files": [
    "src",
    "pkg",
    "dist",
    "README.md"
  ],
  "type": "module",
  "main": "./dist/index.js",
  "types": "./dist/index.d.ts",
  "exports": {
    ".": {
      "types": "./dist/index.d.ts",
      "default": "./dist/index.js"
    },
    "./wasm": {
      "types": "./dist/wasm/index.d.ts",
      "browser": "./dist/wasm/browser.js",
      "default": "./dist/wasm/index.js"
    },
    "./wasm/browser": {
      "types": "./dist/wasm/browser.d.ts",
      "default": "./dist/wasm/browser.js"
    },
    "./pkg/spackle_wasm_bg.wasm": {
      "default": "./pkg/spackle_wasm_bg.wasm"
    }
  },
  "scripts": {
    "build:ts": "tsc -p tsconfig.build.json",
    "test": "bun test",
    "demo": "bun scripts/demo.ts",
    "lint": "oxlint",
    "lint:fix": "oxlint --fix",
    "fmt": "oxfmt",
    "fmt:check": "oxfmt --check"
  },
  "devDependencies": {
    "@types/bun": "latest",
    "@types/node": "^25.9.1",
    "oxfmt": "^0.52.0",
    "oxlint": "^1.67.0",
    "oxlint-tsgolint": "^0.23.0",
    "typescript": "^6.0.3"
  }
}
